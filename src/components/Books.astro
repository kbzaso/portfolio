---
import { Image } from "astro:assets";

interface Book {
  title: string;
  author: string;
  note: string;
  link?: string;
  /** Paths under /public, e.g. "/books/creative-act.webp". One image shows as a cover; several stack as a pack that fans out on hover. */
  images?: string[];
}

const BOOKS: Book[] = [
  {
    title: "Si lo crees, lo creas",
    author: "Brian Tracy",
    note: "Aprendí cómo nuestros pensamientos y creencias pueden influir en nuestras acciones y resultados.",
    link: "https://contrapunto.cl/products/si-lo-crees-lo-creas",
    images: [
      "https://contrapunto.cl/cdn/shop/files/9789877256093.jpg?v=1737135781",
    ],
  },
];
---

<ul class="flex flex-col gap-14">
  {
    BOOKS.map(({ title, author, note, link, images }) => (
      <li>
        <article class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
          <div class="order-2 md:order-1">
            <h3 class="font-mono text-lg text-yellow-500 dark:text-yellow-100">
              {link ? (
                <a
                  href={link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline decoration-yellow-500/40 underline-offset-4 transition hover:decoration-yellow-500 dark:decoration-yellow-100/40 dark:hover:decoration-yellow-100"
                >
                  {title}
                </a>
              ) : (
                title
              )}
            </h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              {author}
            </p>
            <p class="mt-3 max-w-prose leading-relaxed text-pretty text-gray-700 dark:text-gray-300">
              {note}
            </p>
          </div>

          {images && images.length > 0 && (
            <div class="group order-1 flex shrink-0 md:order-2">
              {images.map((src, i) => (
                <Image
                  src={src}
                  alt={`Cover of ${title}`}
                  width={112}
                  height={168}
                  loading="lazy"
                  decoding="async"
                  class:list={[
                    "aspect-[2/3] w-24 rounded-lg bg-black/10 object-cover shadow-md ring-1 ring-black/20 transition-all duration-300 md:w-28 dark:bg-yellow-500/5 dark:ring-white/20",
                    i % 2 === 0 ? "rotate-2" : "-rotate-2",
                    i > 0 && "-ml-16 group-hover:-ml-4 md:-ml-20",
                  ]}
                  style={`z-index: ${images.length - i}`}
                />
              ))}
            </div>
          )}
        </article>
      </li>
    ))
  }
</ul>

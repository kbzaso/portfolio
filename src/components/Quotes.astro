---
interface Quote {
  text: string
  author: string
  source?: string
  url?: string
  /** Optional: why this phrase matters to you. Shown as a collapsible disclosure below the quote. */
  explanation?: string
}

const QUOTES: Quote[] = [
  {
    text: "Si no controlas tu mañana, tu dia te controlara a ti.",
    author: "Brian Tracy",
    source: "Youtube",
    url: "https://www.youtube.com/watch?v=OdfzXlPDPvU",
    explanation:
      "Tomar el control de la mañana te permite establecer prioridades, energía y enfoque antes de que las urgencias o demandas externas dicten cómo debes vivir tu día.",
  },
  {
    text: "Un proceso será el más adecuado para ti cuando se adapte a tus preferencias personales.",
    author: "Scott Belsky",
    source: "Libro: Hacer realidad las ideas",
    url: "https://contrapunto.cl/products/hacer-realidad-las-ideas",
  }
]
---

<ul class="flex flex-col gap-16">
  {
    QUOTES.map(({ text, author, source, explanation, url }) => (
      <li>
        <figure class="relative pl-8 md:pl-10">
          <span
            aria-hidden="true"
            class="absolute left-0 -top-2 font-serif text-5xl leading-none text-yellow-500 dark:text-yellow-100 select-none"
          >
            &ldquo;
          </span>
          <blockquote class="text-pretty text-xl font-light leading-relaxed text-gray-700 dark:text-gray-300 md:text-2xl">
            {text}
          </blockquote>
          <figcaption class="mt-4 font-mono text-sm text-yellow-500 dark:text-yellow-100">
            &mdash; {author}
            {source && (
              <cite class="not-italic text-gray-500 dark:text-gray-400">
                {" "}&middot; <a href={url} class="hover:underline" target="_blank" rel="noopener noreferrer">
                  {source}
                </a>
              </cite>
            )}
          </figcaption>

          {explanation && (
            <details class="group mt-3">
              <summary class="inline-flex cursor-pointer select-none items-center gap-1.5 font-mono text-xs text-gray-500 transition hover:text-yellow-500 dark:text-gray-400 dark:hover:text-yellow-100 list-none [&::-webkit-details-marker]:hidden">
                <span
                  aria-hidden="true"
                  class="inline-block transition-transform duration-200 group-open:rotate-90"
                >
                  &rsaquo;
                </span>
                why this one
              </summary>
              <p class="mt-3 max-w-prose border-l border-yellow-500/40 pl-4 text-pretty text-sm leading-relaxed text-gray-600 dark:border-yellow-100/30 dark:text-gray-400">
                {explanation}
              </p>
            </details>
          )}
        </figure>
      </li>
    ))
  }
</ul>

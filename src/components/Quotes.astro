---
interface Quote {
  text: string;
  author: string;
  source?: string;
  url?: string;
  /** Optional: why this phrase matters to you. Shown as a collapsible disclosure below the quote. */
  explanation?: string;
}

const QUOTES: Quote[] = [
  {
    text: "La cultura no se impone por la fuerza, lo único que podemos hacer es dar el ejemplo.",
    author: "Mark Shayler",
    source: "Libro: ENCUENTRA TU VOZ / Claves para hablar en público.",
    url: "https://koanlibros.com/libro/encuentra-tu-voz",
    explanation:
      "La cultura de una organización se construye a través de las acciones y comportamientos de sus miembros. No se puede imponer, sino que se debe liderar con el ejemplo, demostrando los valores y principios que se desean ver reflejados en la cultura organizacional.",
  },
  {
    text: "Si no controlas tu mañana, tu dia te controlara a ti.",
    author: "Brian Tracy",
    source: "Youtube",
    url: "https://www.youtube.com/watch?v=OdfzXlPDPvU",
    explanation:
      "Tomar el control de la mañana te permite establecer prioridades, energía y enfoque antes de que las urgencias o demandas externas dicten cómo debes vivir tu día.",
  },
  {
    text: "Un proceso será el más adecuado para ti cuando se adapte a tus preferencias personales.",
    author: "Scott Belsky",
    source: "Libro: Hacer realidad las ideas",
    url: "https://contrapunto.cl/products/hacer-realidad-las-ideas",
  },
];
---

<ul class="flex flex-col gap-16">
  {
    QUOTES.map(({ text, author, source, explanation, url }) => (
      <li>
        <figure class="relative pl-8 md:pl-10">
          <span
            aria-hidden="true"
            class="absolute -top-2 left-0 font-serif text-5xl leading-none text-yellow-500 select-none dark:text-yellow-100"
          >
            &ldquo;
          </span>
          <blockquote class="text-xl leading-relaxed font-light text-pretty text-gray-700 md:text-2xl dark:text-gray-300">
            {text}
          </blockquote>
          <figcaption class="mt-4 font-mono text-sm text-yellow-500 dark:text-yellow-100">
            &mdash; {author}
            {source && (
              <cite class="text-gray-500 not-italic dark:text-gray-400">
                {" "}
                &middot;{" "}
                <a
                  href={url}
                  class="hover:underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {source}
                </a>
              </cite>
            )}
          </figcaption>

          {explanation && (
            <details class="group mt-3">
              <summary class="inline-flex cursor-pointer list-none items-center gap-1.5 font-mono text-xs text-gray-500 transition select-none hover:text-yellow-500 dark:text-gray-400 dark:hover:text-yellow-100 [&::-webkit-details-marker]:hidden">
                <span
                  aria-hidden="true"
                  class="inline-block transition-transform duration-200 group-open:rotate-90"
                >
                  &rsaquo;
                </span>
                why this one
              </summary>
              <p class="mt-3 max-w-prose border-l border-yellow-500/40 pl-4 text-sm leading-relaxed text-pretty text-gray-600 dark:border-yellow-100/30 dark:text-gray-400">
                {explanation}
              </p>
            </details>
          )}
        </figure>
      </li>
    ))
  }
</ul>
